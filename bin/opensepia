#!/usr/bin/env python3
"""OpenSepia — AI Dev Team CLI."""

import os
import sys

# Resolve symlinks to find the real project directory
script_path = os.path.realpath(__file__)
project_dir = os.path.dirname(os.path.dirname(script_path))
os.chdir(project_dir)
sys.path.insert(0, project_dir)

from opensepia.cli import main

main()
