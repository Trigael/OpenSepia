#!/usr/bin/env python3
"""OpenSepia — AI Dev Team CLI."""

import os
import sys

# Use CWD to find the opensepia package (so the right project version runs)
cwd = os.getcwd()
if os.path.isdir(os.path.join(cwd, "opensepia")):
    sys.path.insert(0, cwd)
else:
    # Fallback: resolve symlinks to find the package location
    script_path = os.path.realpath(__file__)
    project_dir = os.path.dirname(os.path.dirname(script_path))
    sys.path.insert(0, project_dir)

from opensepia.cli import main

main()
