# =============================================================================
# Board Provider — choose ONE (Board Server, GitLab, or GitHub)
# Auto-detection priority: Board Server > GitLab > GitHub
# =============================================================================

# ----- Board Server (self-hosted, recommended) -----
# BOARD_SERVER_URL=http://localhost:8080

# ----- GitLab -----
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-INSERT-TOKEN-HERE
GITLAB_PROJECT_ID=group/project-name

# ----- GitHub (alternative to GitLab) -----
# GITHUB_TOKEN=ghp_INSERT-TOKEN-HERE
# GITHUB_OWNER=my-org
# GITHUB_REPO=my-project
# GITHUB_API_URL=https://api.github.com  # optional, for GitHub Enterprise

# =============================================================================
# Git — workspace is the git repo (project/workspace/)
# Initialize with: cd project/workspace && git init && git remote add origin <url>
# =============================================================================
GIT_REPO_URL=https://gitlab.com/group/project-name.git
GIT_USER_NAME=AI Dev Team
GIT_USER_EMAIL=ai-team@company.com
GIT_MAIN_BRANCH=main
GIT_AUTO_PUSH=true
# For HTTPS auth (preferred):
GIT_TOKEN=glpat-INSERT-TOKEN-HERE
# For SSH auth:
# GIT_SSH_KEY=/root/.ssh/id_ed25519

# =============================================================================
# Docker (for the DevOps agent - runs inside LXC)
# =============================================================================
# Docker socket (if not default)
# DOCKER_HOST=unix:///var/run/docker.sock

# Registry for push/pull (optional)
# DOCKER_REGISTRY=registry.gitlab.com
# DOCKER_REGISTRY_USER=deploy-token
# DOCKER_REGISTRY_PASS=token-password

# Prefix for image names (optional)
# DOCKER_IMAGE_PREFIX=mycompany/

# Docker-compose file (default: docker-compose.yml)
# DOCKER_COMPOSE_FILE=docker-compose.yml

# Security limits
DOCKER_MAX_CONTAINERS=10
DOCKER_ALLOWED_NETWORKS=bridge,host
